{
  "name": "ito",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w apps/server run dev",
    "dev:client": "npm -w apps/client run dev",
    "build": "npm -w packages/shared run build && npm -w apps/server run build && npm -w apps/client run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
